{
  "name": "hackunion-v2",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "styles:compile": "mkdir -p styles public/styles && sass src/styles/main.scss styles/site.css --no-source-map --style=expanded && cp styles/site.css public/styles/site.css",
    "styles:watch": "mkdir -p styles && sass src/styles/main.scss styles/site.css --no-source-map --style=expanded --watch --poll",
    "predev": "npm run styles:compile",
    "prebuild": "npm run styles:compile",
    "dev": "concurrently -k \"npm:styles:watch\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "sass": "^1.80.7",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "jspdf": "^4.2.1",
    "lenis": "^1.1.14",
    "lucide": "^0.468.0",
    "xlsx": "^0.18.5"
  }
}
